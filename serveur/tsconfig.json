{
	"compilerOptions": {
		"rootDir": ".",
		"outDir": "./dist",
		"module": "esnext",
		"target": "esnext",
		"types": ["node"],
		"lib": ["esnext"],
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": false,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts", "database/**/*.ts"],
	"exclude": ["node_modules", "dist", "**.sql"]
}
